# Azure DevOps Configuration
# Copy this file to .env and fill in your actual values

# Your Azure DevOps organization name (from https://dev.azure.com/{org})
AZURE_DEVOPS_ORG=<organization-name>

# Your Azure DevOps project name
AZURE_DEVOPS_PROJECT=<project-name>

# Personal Access Token with Code (Read & Write) and Pull Request permissions
# Generate at: https://dev.azure.com/{org}/_usersSettings/tokens
AZURE_DEVOPS_PAT=<your-pat-token>
